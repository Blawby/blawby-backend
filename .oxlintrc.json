{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "import",
    "typescript",
    "node"
  ],
  "jsPlugins": [
    "oxlint-plugin-eslint"
  ],
  "env": {
    "node": true,
    "es2022": true
  },
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "style": "off",
    "perf": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {},
  "overrides": [
    {
      "files": [
        "src/**/*.{js,ts,tsx}"
      ],
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_",
            "caughtErrorsIgnorePattern": "^_"
          }
        ],
        "eslint-js/prefer-const": "error",
        "typescript/no-explicit-any": "error",
        "typescript/no-deprecated": "error",
        "import/first": "error",
        "import/no-duplicates": "error"
      }
    },
    {
      "files": [
        "scripts/**/*.ts"
      ],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/.agent/**",
    "**/.agents/**",
    "**/.claude/**",
    "**/.cursor/**",
    "**/.serena/**"
  ]
}

{
  "name": "blawby-backend",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "src/hono-app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx watch src/hono-server.ts",
    "dev:full": "concurrently \"ENABLE_QUEUE=true pnpm run dev\" \"pnpm run event-worker:dev\" \"pnpm run email-worker:dev\" --names \"API,EVENT,EMAIL\" --prefix-colors \"blue,green,magenta\"",
    "event-worker": "node dist/workers/event.worker.js",
    "event-worker:dev": "tsx watch src/workers/event.worker.ts",
    "email-worker": "node dist/workers/email.worker.js",
    "email-worker:dev": "tsx watch src/workers/email.worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sync:plans": "tsx src/scripts/syncSubscriptionPlans.ts",
    "sync:schemas": "tsx scripts/sync-schemas.ts",
    "sync:listeners": "tsx scripts/sync-listeners.ts",
    "init:preferences": "tsx scripts/initialize-user-preferences.ts",
    "format": "eslint --fix .",
    "format:check": "eslint .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "node dist/hono-server.js",
    "start:all": "concurrently \"pnpm start\" \"pnpm run event-worker\" \"pnpm run email-worker\" --names \"API,EVENT,EMAIL\" --prefix-colors \"blue,green,magenta\"",
    "test": "cross-env APP_ENV=test tap test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@better-auth/stripe": "^1.4.18",
    "@casl/ability": "^6.8.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.0",
    "@logtape/file": "^2.0.0",
    "@logtape/hono": "^2.0.0",
    "@logtape/logtape": "^2.0.0",
    "@scalar/hono-api-reference": "^0.9.39",
    "@scalar/openapi-to-markdown": "^0.3.35",
    "better-auth": "1.4.18",
    "close-with-grace": "2.4.0",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "es-toolkit": "^1.44.0",
    "graphile-worker": "^0.16.6",
    "hono": "^4.11.7",
    "mjml": "^4.17.2",
    "path-to-regexp": "^8.3.0",
    "pg": "8.18.0",
    "rate-limiter-flexible": "^9.0.1",
    "resend": "^6.9.1",
    "stripe": "^20.2.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@tapjs/test": "4.3.0",
    "@types/mjml": "^4.7.4",
    "@types/node": "25.1.0",
    "@types/pg": "8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "concurrently": "^9.2.1",
    "cross-env": "10.1.0",
    "drizzle-kit": "0.31.8",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-oxlint": "^1.42.0",
    "husky": "9.1.7",
    "oxlint": "1.42.0",
    "tap": "21.5.0",
    "ts-node": "10.9.2",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "tap": {
    "plugin": [
      "!@tapjs/typescript"
    ],
    "node-arg": [
      "--import",
      "tsx"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.17.0"
  }
}

{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "noEmit": true,
    "types": [
      "vitest/globals",
      "node"
    ],
    "paths": {
      "@/test/*": [
        "./*"
      ],
      "@/*": [
        "../src/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ]
}
